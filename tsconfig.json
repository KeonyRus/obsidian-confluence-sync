{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"noImplicitAny": true,
		"allowSyntheticDefaultImports": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"outDir": "./dist",
		"rootDir": "./src",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"]
}
